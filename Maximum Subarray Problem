#include <stdio.h>
#include <limits.h>

int max(int a, int b) {
    return (a > b) ? a : b;
}

int maxCrossingSum(int arr[], int left, int mid, int right) {

    int sum = 0;
    int left_sum = INT_MIN;

    for(int i = mid; i >= left; i--) {
        sum += arr[i];
        if(sum > left_sum)
            left_sum = sum;
    }

    sum = 0;
    int right_sum = INT_MIN;

    for(int i = mid + 1; i <= right; i++) {
        sum += arr[i];
        if(sum > right_sum)
            right_sum = sum;
    }

    return left_sum + right_sum;
}

int maxSubArray(int arr[], int left, int right) {

    if(left == right)
        return arr[left];

    int mid = (left + right) / 2;

    int left_max = maxSubArray(arr, left, mid);
    int right_max = maxSubArray(arr, mid+1, right);
    int cross_max = maxCrossingSum(arr, left, mid, right);

    return max(max(left_max, right_max), cross_max);
}

int main() {

    int arr[] = {-2,1,-3,4,-1,2,1,-5,4};
    int n = 9;

    int result = maxSubArray(arr, 0, n-1);

    printf("Maximum Subarray Sum = %d", result);

    return 0;
}
