#include <stdio.h>

int main() {
    int path[] = {1, 3, 5}; 
    int path_length = 3;

    
    int graph[6][6] = {0};
    graph[1][3] = 1;
    graph[3][5] = 1;

    int valid = 1;
    for(int i=0; i<path_length-1; i++) {
        if(graph[path[i]][path[i+1]] == 0) {
            valid = 0;
            break;
        }
    }

    if(valid)
        printf("Path is valid\n");
    else
        printf("Path is invalid\n");

    return 0;
}
