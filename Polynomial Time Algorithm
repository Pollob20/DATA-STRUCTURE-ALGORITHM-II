#include <stdio.h>
#include <limits.h>

#define MAX 100

int dp[MAX][MAX];


int matrixChain(int p[], int n) {

    for(int i = 1; i < n; i++)
        dp[i][i] = 0;

    for(int len = 2; len < n; len++) {

        for(int i = 1; i < n - len + 1; i++) {
            int j = i + len - 1;
            dp[i][j] = INT_MAX;

            for(int k = i; k < j; k++) {
                int cost = dp[i][k] + dp[k+1][j]
                         + p[i-1] * p[k] * p[j];

                if(cost < dp[i][j])
                    dp[i][j] = cost;
            }
        }
    }

    return dp[1][n-1];
}

int main() {
    int arr[] = {10, 20, 30, 40, 30};
    int n = sizeof(arr)/sizeof(arr[0]);

    printf("Minimum multiplication cost: %d\n", matrixChain(arr, n));

    return 0;
}
