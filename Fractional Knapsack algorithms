#include <stdio.h>
#include <stdlib.h>

struct Item {
    int value;
    int weight;
};

int cmp(const void *a, const void *b) {
    double r1 = (double)((struct Item*)a)->value / ((struct Item*)a)->weight;
    double r2 = (double)((struct Item*)b)->value / ((struct Item*)b)->weight;

    if (r1 < r2) return 1;
    if (r1 > r2) return -1;
    return 0;
}

double fractionalKnapsack(struct Item items[], int n, int W) {
    qsort(items, n, sizeof(items[0]), cmp);

    double totalValue = 0.0;

    for (int i = 0; i < n; i++) {
        if (W == 0) break;

        if (items[i].weight <= W) {
            W -= items[i].weight;
            totalValue += items[i].value;
        } else {
            totalValue += (double)items[i].value * W / items[i].weight;
            W = 0;
        }
    }

    return totalValue;
}

int main() {
    struct Item items[] = {{60, 10}, {100, 20}, {120, 30}};
    int n = sizeof(items) / sizeof(items[0]);
    int W = 50;

    double result = fractionalKnapsack(items, n, W);

    printf("Maximum value = %.2f\n", result);

    return 0;
}
