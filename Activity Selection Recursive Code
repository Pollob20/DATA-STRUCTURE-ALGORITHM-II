#include <stdio.h>

void recursiveActivity(int start[], int finish[], int i, int n) {

    int j = i + 1;

    while(j < n && start[j] < finish[i])
        j++;

    if(j < n) {
        printf("%d ", j);
        recursiveActivity(start, finish, j, n);
    }
}

int main() {

    int start[]  = {1, 3, 0, 5, 8, 5};
    int finish[] = {2, 4, 6, 7, 9, 9};

    int n = 6;

    printf("Selected activities:\n");
    printf("0 ");

    recursiveActivity(start, finish, 0, n);

    return 0;
}
