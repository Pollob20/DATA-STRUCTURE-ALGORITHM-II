#include <stdio.h>
#include <limits.h>

int main(){
    int arr[] = {1, 2, 3, 4};
    int n = sizeof(arr)/sizeof(arr[0]);
    int m[n][n];

    for(int i=1;i<n;i++) m[i][i]=0;

    for(int L=2; L<n; L++){
        for(int i=1;i<n-L+1;i++){
            int j=i+L-1;
            m[i][j]=INT_MAX;
            for(int k=i;k<=j-1;k++){
                int q = m[i][k]+m[k+1][j]+arr[i-1]*arr[k]*arr[j];
                if(q<m[i][j]) m[i][j]=q;
            }
        }
    }

    printf("Minimum number of multiplications = %d\n", m[1][n-1]);
    return 0;
}
