#include <stdio.h>
#include <limits.h>
#define V 5

typedef struct {
    int vertex;
    int dist;
} HashEntry;

HashEntry vertexTable[V]; 

int minDistance(HashEntry table[], int visited[]) {
    int min = INT_MAX, min_index;
    for(int i=0;i<V;i++)
        if(!visited[i] && table[i].dist <= min)
            min = table[i].dist, min_index=i;
    return min_index;
}

void dijkstra(int graph[V][V], int src){
    int visited[V] = {0};
    for(int i=0;i<V;i++) { vertexTable[i].vertex=i; vertexTable[i].dist=INT_MAX;}
    vertexTable[src].dist=0;

    for(int count=0; count<V-1; count++){
        int u = minDistance(vertexTable, visited);
        visited[u]=1;
        for(int v=0;v<V;v++)
            if(!visited[v] && graph[u][v] && vertexTable[u].dist!=INT_MAX &&
               vertexTable[u].dist + graph[u][v] < vertexTable[v].dist)
                vertexTable[v].dist = vertexTable[u].dist + graph[u][v];
    }

    for(int i=0;i<V;i++)
        printf("Vertex %d Distance: %d\n", vertexTable[i].vertex, vertexTable[i].dist);
}

int main() {
    int graph[V][V] = {
        {0,2,0,6,0},
        {2,0,3,8,5},
        {0,3,0,0,7},
        {6,8,0,0,9},
        {0,5,7,9,0}
    };
    dijkstra(graph,0);
    return 0;
}
