#include <stdio.h>

int main() {
    int weights[] = {2,3,4,5};
    int values[]  = {3,4,5,6};
    int n = 4, W = 5;

    int selected[] = {0,1,0,0}; 
    int total_weight = 0, total_value = 0;

    for(int i=0; i<n; i++){
        if(selected[i]){
            total_weight += weights[i];
            total_value += values[i];
        }
    }

    if(total_weight <= W)
        printf("Valid solution, total value: %d\n", total_value);
    else
        printf("Invalid solution, exceeds capacity\n");

    return 0;
}
