#include <bits/stdc++.h>
using namespace std;

#define INF INT_MAX

void dijkstra(int n, vector<pair<int,int>> adj[], int src) {
    vector<int> dist(n, INF);
    dist[src] = 0;

    priority_queue<pair<int,int>, vector<pair<int,int>>, greater<pair<int,int>>> pq;
    pq.push({0, src});

    while (!pq.empty()) {
        int u = pq.top().second;
        int d = pq.top().first;
        pq.pop();

        for (auto edge : adj[u]) {
            int v = edge.first;
            int weight = edge.second;

            // Relaxation step
            if (dist[u] + weight < dist[v]) {
                dist[v] = dist[u] + weight;
                pq.push({dist[v], v});
            }
        }
    }

    for (int i = 0; i < n; i++) {
        cout << "Distance from source to " << i << " = " << dist[i] << endl;
    }
}

int main() {
    int n = 5;
    vector<pair<int,int>> adj[n];

    adj[0].push_back({1, 10});
    adj[0].push_back({2, 5});
    adj[1].push_back({3, 1});
    adj[2].push_back({1, 3});
    adj[2].push_back({3, 8});
    adj[2].push_back({4, 2});
    adj[3].push_back({4, 4});
    adj[4].push_back({3, 6});

    dijkstra(n, adj, 0);

    return 0;
}
