#include <stdio.h>
#include <stdlib.h>

#define TABLE_SIZE 11
#define LOAD_FACTOR 0.7

typedef struct {
    int key;
    int status; } HashNode;

HashNode* table;
int size = TABLE_SIZE;
int count = 0;


int h1(int key) {
    return key % size;
}


int h2(int key) {
    return 7 - (key % 7);
}

void initTable() {
    table = (HashNode*)malloc(size * sizeof(HashNode));
    for(int i = 0; i < size; i++) {
        table[i].status = 0;
    }
}

void rehash();

void insert(int key) {
    if((float)count / size >= LOAD_FACTOR) {
        rehash();
    }

    int i = 0;
    int index;

    while(i < size) {
        index = (h1(key) + i * h2(key)) % size;

        if(table[index].status != 1) {
            table[index].key = key;
            table[index].status = 1;
            count++;
            return;
        }
        i++;
    }
}

int search(int key) {
    int i = 0, index;

    while(i < size) {
        index = (h1(key) + i * h2(key)) % size;

        if(table[index].status == 0)
            return -1;

        if(table[index].status == 1 && table[index].key == key)
            return index;

        i++;
    }
    return -1;
}

void deleteKey(int key) {
    int index = search(key);
    if(index != -1) {
        table[index].status = -1; // lazy delete
        count--;
    }
}

void rehash() {
    HashNode* oldTable = table;
    int oldSize = size;

    size = size * 2;
    count = 0;

    initTable();

    for(int i = 0; i < oldSize; i++) {
        if(oldTable[i].status == 1) {
            insert(oldTable[i].key);
        }
    }

    free(oldTable);
}

void display() {
    for(int i = 0; i < size; i++) {
        if(table[i].status == 1)
            printf("[%d] -> %d\n", i, table[i].key);
        else
            printf("[%d] -> NULL\n", i);
    }
}

int main() {
    initTable();

    insert(21);
    insert(32);
    insert(43);
    insert(54);
    insert(65);

    display();

    printf("Search 43: %d\n", search(43));

    deleteKey(43);
    printf("After deletion:\n");
    display();

    return 0;
}
