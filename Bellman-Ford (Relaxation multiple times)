#include <bits/stdc++.h>
using namespace std;

#define INF 1e9

struct Edge {
    int u, v, w;
};

void bellmanFord(int n, vector<Edge>& edges, int src) {
    vector<int> dist(n, INF);
    dist[src] = 0;

    for (int i = 0; i < n - 1; i++) {
        for (auto e : edges) {
            // Relaxation
            if (dist[e.u] + e.w < dist[e.v]) {
                dist[e.v] = dist[e.u] + e.w;
            }
        }
    }

    for (int i = 0; i < n; i++) {
        cout << "Distance to " << i << " = " << dist[i] << endl;
    }
}

int main() {
    int n = 5;
    vector<Edge> edges = {
        {0,1,6}, {0,2,7}, {1,3,5}, {2,3,8}, {3,4,2}
    };

    bellmanFord(n, edges, 0);
}
